{
  "name": "bsky-painter",
  "version": "1.0.0",
  "description": "An extension to customize bluesky appearance",
  "keywords": [
    "firefox",
    "zen",
    "bluesky",
    "bsky",
    "theme"
  ],
  "license": "GPL-3.0-only",
  "author": "Andrea Coronese <sixpounder@protonmail.com>",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "rolldown --config --watch",
    "build": "rolldown --config",
    "browser:firefox": "web-ext run --watch-files --start-url bsky.app --devtools --source-dir ./dist",
    "lint": "npm run build && web-ext lint --source-dir ./dist",
    "package": "web-ext build --source-dir ./dist",
    "preflight:git": "node build/preflight.git.js",
    "publish": "npm run preflight:git && npm run lint && node build/package-and-sign.js"
  },
  "devDependencies": {
    "@types/firefox-webext-browser": "^143.0.0",
    "@web/rollup-plugin-copy": "^0.5.1",
    "inquirer": "^13.3.2",
    "rolldown": "^1.0.0-rc.10",
    "typescript": "^5.9.3",
    "web-ext": "^10.0.0"
  }
}
