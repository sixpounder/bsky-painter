{
  "name": "bsky-painter",
  "version": "1.3.0",
  "description": "An extension to customize bluesky appearance",
  "keywords": [
    "firefox",
    "zen",
    "bluesky",
    "bsky",
    "theme"
  ],
  "license": "GPL-3.0-only",
  "author": "Andrea Coronese <sixpounder@protonmail.com>",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf ./dist && rimraf ./web-ext-artifacts",
    "dev": "rolldown --config --watch",
    "build": "rolldown --config",
    "browser:firefox": "web-ext run --watch-files --start-url bsky.app --devtools --source-dir ./dist",
    "lint": "eslint . && npm run build && web-ext lint --source-dir ./dist",
    "package": "web-ext build --source-dir ./dist",
    "preflight:git": "node build/preflight.git.js",
    "publish": "npm run preflight:git && npm run lint && node build/package-and-sign.js",
    "prepare": "husky",
    "commitlint": "commitlint --edit \"$1\""
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/webextension-polyfill": "^0.12.5",
    "@web/rollup-plugin-copy": "^0.5.1",
    "chalk": "^5.6.2",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "inquirer": "^13.3.2",
    "rimraf": "^6.1.3",
    "rolldown": "^1.0.0-rc.10",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "web-ext": "^10.0.0"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  }
}
